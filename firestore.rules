rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global helper primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 2. Client-side entity schema validator
    function isValidUserProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && (!('membershipStatus' in data) || data.membershipStatus == null || data.membershipStatus == 'Active' || data.membershipStatus == 'Pending' || data.membershipStatus == 'None')
        && (!('membershipPlanId' in data) || data.membershipPlanId == null || data.membershipPlanId is string)
        && (!('memberSince' in data) || data.memberSince == null || data.memberSince is string)
        && (!('qrCodeValue' in data) || data.qrCodeValue == null || data.qrCodeValue is string)
        && (!('bookings' in data) || data.bookings == null || data.bookings is list)
        && (!('payments' in data) || data.payments == null || data.payments is list);
    }

    // 3. Fortress rules for Users profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId) 
        && isValidUserProfile(incoming())
        && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) 
        && isValidUserProfile(incoming())
        && incoming().email == existing().email
        && (!('memberSince' in existing()) || incoming().memberSince == existing().memberSince);
      allow delete: if isOwner(userId);
    }
    
    // 4. Newsletter subscriber writes (Write-only for privacy)
    match /newsletters/{newsletterId} {
      allow create: if isValidId(newsletterId)
        && incoming().email is string && incoming().email.size() <= 120
        && (incoming().subscribedAt is string || incoming().subscribedAt == request.time);
      allow get, list, update, delete: if false;
    }
  }
}
